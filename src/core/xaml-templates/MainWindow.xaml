<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="{{APP_NAME}}">

    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Spacing="20">

        <TextBlock
            x:Name="titleText"
            Text="Welcome to {{APP_NAME}}!"
            FontSize="28"
            FontWeight="Bold"
            HorizontalAlignment="Center" />

        <TextBlock
            x:Name="statusText"
            Text="Built with WinUIDevKit"
            FontSize="14"
            Foreground="Gray"
            HorizontalAlignment="Center" />

        <Button
            x:Name="helloButton"
            Content="Click me"
            FontSize="18"
            Padding="24,12"
            HorizontalAlignment="Center" />

    </StackPanel>
</Window>
