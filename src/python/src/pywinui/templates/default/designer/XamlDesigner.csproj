<Project Sdk="Microsoft.NET.Sdk">
  <!--
    This is a lightweight .csproj shim that lets Visual Studio / Blend
    open and preview your XAML files with full IntelliSense and designer
    support. The actual app logic lives in Python code-behind files.

    Usage:
      1. Open this .csproj (or the parent .sln) in Visual Studio
      2. Edit XAML files with the visual designer or XAML editor
      3. Save and return to VS Code / pywinui for the Python side

    This project does NOT build a real .NET app – it only provides
    design-time XAML support.
  -->

  <PropertyGroup>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <OutputType>Library</OutputType>
    <!-- Suppress build – this is design-time only -->
    <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.5.*" />
  </ItemGroup>

  <!-- Include all XAML files from the app/ folder -->
  <ItemGroup>
    <Page Include="app\**\*.xaml" SubType="Designer" Generator="MSBuild:Compile" />
  </ItemGroup>

</Project>
