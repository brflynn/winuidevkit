<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="HelloWorld">

    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Spacing="20">

        <TextBlock
            x:Name="titleText"
            Text="Hello, pywinui!"
            FontSize="32"
            FontWeight="Bold"
            HorizontalAlignment="Center" />

        <TextBlock
            x:Name="statusText"
            Text="Press the button below"
            FontSize="16"
            Foreground="Gray"
            HorizontalAlignment="Center" />

        <Button
            x:Name="helloButton"
            Content="Click me"
            FontSize="18"
            Padding="24,12"
            HorizontalAlignment="Center" />

        <Button
            x:Name="dialogButton"
            Content="Open Dialog"
            FontSize="18"
            Padding="24,12"
            HorizontalAlignment="Center" />

    </StackPanel>
</Window>
