<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="HelloWorld">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <TextBlock x:Name="greeting" Text="Hello from WinUI3!" FontSize="28" HorizontalAlignment="Center"/>
        <Button x:Name="clickButton" Content="Click me" HorizontalAlignment="Center"/>
        <TextBlock x:Name="counter" Text="Clicks: 0" FontSize="16" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
